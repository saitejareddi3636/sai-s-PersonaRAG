# Copy to backend/.env for local runs. Do not commit secrets.

APP_NAME=ai-portfolio-agent API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Production (Vercel UI): add your origin, e.g. https://your-app.vercel.app
# Also set repo-root `.env` for compose: CORS_ORIGINS=... (see compose.env.example)
LOG_LEVEL=INFO

# Optional: repository root when running `python -m app.rag.ingest` from an unusual cwd
# INGEST_REPO_ROOT=/absolute/path/to/ai-portfolio-agent

# Retrieval (defaults: Ollama embeddings via local API)
# CHUNKS_JSON_PATH=/absolute/path/to/data/processed/chunks.json
# RETRIEVAL_BACKEND=auto
# RETRIEVAL_TOP_K=5
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_MODEL=qwen2.5:3b
# OLLAMA_EMBED_MODEL=nomic-embed-text

# STT: Faster-Whisper (voice input)
STT_PROVIDER=faster-whisper
STT_MODEL_SIZE=base
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=1

# TTS: piper (default) | mock | local-service
# Docker image ships Piper + en_US-lessac-low; compose sets PIPER_MODEL_PATH explicitly.
# Local: install piper and set model path, e.g.:
# PIPER_MODEL_PATH=/absolute/path/en_US-lessac-medium.onnx
TTS_PROVIDER=piper
PIPER_BINARY=piper
PIPER_MODEL_PATH=

# Ollama: keep model in memory between requests (lower latency). Use 0 to unload after each call.
# OLLAMA_KEEP_ALIVE=15m
# Optional: set only for multi-speaker models, e.g. PIPER_SPEAKER_ID=0

# XTTS disabled in active runtime.
# CLEAN_TTS_URL=http://127.0.0.1:8010
