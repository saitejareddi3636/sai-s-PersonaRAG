# Copy to backend/.env for local runs. Do not commit secrets.

APP_NAME=ai-portfolio-agent API
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Optional: repository root when running `python -m app.rag.ingest` from an unusual cwd
# INGEST_REPO_ROOT=/absolute/path/to/ai-portfolio-agent

# Retrieval (defaults: TF–IDF if OPENAI_API_KEY unset; else OpenAI embeddings)
# CHUNKS_JSON_PATH=/absolute/path/to/data/processed/chunks.json
# RETRIEVAL_BACKEND=auto
# RETRIEVAL_TOP_K=5
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Below this TF–IDF score, prompts nudge the model toward lower confidence
# RETRIEVAL_WEAK_SCORE_THRESHOLD=0.06

# Bounded in-memory chat history (per session_id); replace store with Redis later if needed
# SESSION_MAX_MESSAGES=12
# SESSION_MAX_TOTAL_CHARS=4000
